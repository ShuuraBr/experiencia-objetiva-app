PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# sqlite para desenvolvimento local
DB_CLIENT=sqlite

# mysql para producao na Hostinger
DB_CLIENT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=seu_usuario
DB_PASSWORD=sua_senha
DB_NAME=seu_banco

# opcional: string unica no padrao mysql://usuario:senha@host:3306/banco
# DATABASE_URL=mysql://usuario:senha@localhost:3306/banco
